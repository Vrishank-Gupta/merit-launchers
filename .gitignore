/docs/math_manual_paper*/
/docs/*_zoom*.png
/docs/_pending_math_patch.json

# Marketing site build artifacts
/marketing/node_modules/
/marketing/dist/
/marketing/.env.local

# Intermediate React build used by local build script (deployed via SCP, not git)
/deploy/marketing-site/

# Runtime user-uploaded files (served by nginx volumes, not stored in git)
/server/blog-images/*
!/server/blog-images/.gitkeep
/server/toolkit-files/*
!/server/toolkit-files/.gitkeep

# Vendored plugin/examples kept local only
/vendor/razorpay_flutter/example/
/vendor/razorpay_flutter/test/
/vendor/razorpay_flutter/local.properties

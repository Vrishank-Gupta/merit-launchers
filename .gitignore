app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/app/upload
/build/app/outputs/flutter-apk/*.apk
/build/app/outputs/bundle/

# Local SDK/tooling
.tools/

# Generated local admin web bundle
/deploy/admin-web/
/deploy/portal-build/
/deploy/*.tar.gz
/deploy/certs/
/deploy/letsencrypt/
/tmp_ocr_test/
/checkgpu.py
/android_debug_screen.png
/docs/*.png
